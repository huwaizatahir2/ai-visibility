# Copy to arbisoft.tfvars and fill in. One tfvars + workspace per organization.
region        = "us-east-1"
name          = "ai-visibility"
instance_type = "t3.small"

# Existing EC2 key pair name for SSH.
key_pair_name = "my-keypair"

# CIDR allowed to SSH (your office/VPN egress IP, e.g. "203.0.113.4/32").
admin_cidr = "203.0.113.0/24"
